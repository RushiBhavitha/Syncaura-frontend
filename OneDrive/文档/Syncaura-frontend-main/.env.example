# ─────────────────────────────────────────────────────────────────────────────
# Syncaura Frontend — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in the values below for your environment
#   3. NEVER commit your real .env file to Git (it is already in .gitignore)
#   4. All variables exposed to the browser MUST start with VITE_
# ─────────────────────────────────────────────────────────────────────────────


# ── Backend API ───────────────────────────────────────────────────────────────
# Base URL of the backend server (no trailing slash, no /api suffix)
# Development:  http://localhost:5000
# Production:   https://api.your-domain.com
VITE_API_URL=http://localhost:5000


# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# Your GitHub OAuth App credentials.
# Register at: https://github.com/settings/developers → OAuth Apps
#
# Client ID:    Shown on the OAuth App settings page (safe to expose in frontend)
# Redirect URI: Must EXACTLY match what you registered in the GitHub OAuth App settings
#
# ⚠️  Client Secret belongs ONLY on the backend — NEVER put it here.
#
# Development:
VITE_GITHUB_CLIENT_ID=your_github_oauth_app_client_id
VITE_GITHUB_REDIRECT_URI=http://localhost:5173/auth/github/callback
#
# Production (uncomment and fill):
# VITE_GITHUB_CLIENT_ID=your_production_github_client_id
# VITE_GITHUB_REDIRECT_URI=https://your-domain.com/auth/github/callback


# ── App Info ──────────────────────────────────────────────────────────────────
# Used in page titles, meta tags, etc.
VITE_APP_NAME=Syncaura
VITE_APP_VERSION=1.0.0
